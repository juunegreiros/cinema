// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Movie {
  id                  String    @id @default(uuid())
  title               String     
  durationMinutes     Int   
  ageRating           AgeRate  
  active              Boolean
  createdAt           DateTime  @default(now()) // saber quando foi criado
  updatedAt           DateTime  @updatedAt // saber quando foi alterado

  sessions            Session[] // indica relação desse model com o Session
}

enum AgeRate { // opções disponiveis dentro do ageRating
  None
  PG_10 // PG = Parental Guidance
  PG_12 
  PG_14
  R_16  // R = Restricted
  NC_18 // NC = No Children Under..
}

model Room {
  id          String    @id @default(uuid())
  name        String
  type        RoomType
  active      Boolean
  createdAt   DateTime  @default(now()) // saber quando foi criado
  updatedAt   DateTime  @updatedAt // saber quando foi alterado

  seats       Seat[] // indica relação com o model Seat
  sessions    Session[] // indica relaçao com o model Session
}

enum RoomType { // opções disponiveis no type
  NORMAL
  PRO_MAX
  VIP
}

model Seat {
  id          String    @id @default(uuid())
  identifier  String
  roomId      String
  active      Boolean
  createdAt   DateTime  @default(now()) // saber quando foi criado
  updatedAt   DateTime  @updatedAt // saber quando foi alterado

  room        Room      @relation(fields: [roomId], references: [id]) // Cria a relaçao com o model room e indica os campos que vão ser consultados

  bookings Booking[] // indica relaçao com o model Booking

  @@unique([roomId, identifier]) // bloqueia que exista outro identificador igual na mesma room
}

model Session {
  id                String    @id @default(uuid()) 
  movieId           String
  roomId            String
  durationMinutes   Int
  start             DateTime
  end               DateTime
  createdAt         DateTime  @default(now()) // saber quando foi criado
  updatedAt         DateTime  @updatedAt // saber quando foi alterado

  movie             Movie     @relation(fields: [movieId], references: [id]) // Cria a relação com o model Movie e indica os campos a ser consultados
  room              Room      @relation(fields: [roomId], references: [id])  // Cria a relação com o model Room e indica os campos a ser consultados

  bookings Booking[] // indica a relaçao com o model Booking
}

model Booking {
id            String      @id @default(uuid())
userId        String
sessionId     String
seatId        String
status        BookStatus  @default(PENDING) // define uma opção como default na criação
createdAt     DateTime    @default(now()) // saber quando foi criado
updatedAt     DateTime    @updatedAt // saber quando foi alterado o status

// user        User        @relation(fields: [userId], references: [id]) // Cria a relação com o model User e indica os campos a ser consultados
session     Session     @relation(fields: [sessionId], references: [id]) // Cria a relação com o model Session e indica os campos a ser consultados
seat        Seat        @relation(fields: [seatId], references: [id]) // Cria a relação com o model Seat e indica os campos a ser consultados

viporders VIPOrder[] // indica a relaçao com o model VIPOrder
}

enum BookStatus {
  PENDING
  CONFIRMED
  CANCELLED
  USED 
}

model VIPOrder {
id           String      @id @default(uuid())
userId       String
bookingId    String 
status       VIPStatus
totalValue   Decimal
createdAt    DateTime    @default(now()) // saber quando foi criado
updatedAt    DateTime    @updatedAt // saber quando foi alterado o status

// user        User        @relation(fields: [userId], references: [id]) // Cria a relação com o model User e indica os campos a ser consultados
booking     Booking     @relation(fields: [bookingId], references: [id]) // Cria a relação com o model Booking e indica os campos a ser consultados

orderitems   OrderItem[]  // indica a relaçao com o model OrderItem
}

enum VIPStatus {
  CREATED
  SENT
  DELIVERED
  CANCELLED
}

model OrderItem {
id           String       @id @default(uuid())
VIPOrderId     String
itemId       String
unitPrice    Decimal
amount       Int
createdAt    DateTime    @default(now()) // saber quando foi criado
updatedAt    DateTime    @updatedAt // saber quando foi alterado

vipOrder      VIPOrder      @relation(fields: [VIPOrderId], references: [id]) // Cria a relação com o model VIPOrder e indica os campos a ser consultados
item          Item          @relation(fields: [itemId], references: [id]) // Cria a relação com o model Item e indica os campos a ser consultados
}

model Item {
id             String   @id @default(uuid())
name           String
description    String
currentPrice   Decimal
active         Boolean
createdAt      DateTime    @default(now()) // saber quando foi criado
updatedAt      DateTime    @updatedAt // saber quando foi alterado

orderitems   OrderItem[]  // indica a relaçao com o model OrderItem
}

model Permission {
  id            String @id @default(uuid())
  key           String
  description   String
  role          Role[]
}

model Role {
  id            String @id @default(uuid())
  name          String
  description   String
  permissions   Permission[]
  users         User[]
}

model User {
  id            String @id @default(uuid())
  name          String
  email         String @unique
  password      String
  roles          Role[]
  bookings Booking[]
  vipOrders VIPOrder[]
}
