// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model movie {
  id                  String    @id @default(uuid())
  title               String     
  durationMinutes     Int   
  ageRating           AgeRate  
  active              Boolean
  createdAt           DateTime    @default(now())
}

enum AgeRate {
  LIVRE
  MAIOR_10
  MAIOR_12
  MAIOR_14
  MAIOR_16
  MAIOR_18
}